{
  "manifest_version": 3,
  "name": "Live Subtitles for Browser Videos",
  "version": "1.0.0",
  "description": "High-accuracy live subtitles for any video playing in browser tabs with translation support",
  
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/constants.js",
        "utils/audio-utils.js",
        "content/video-detector.js",
        "content/audio-capture.js",
        "content/subtitle-overlay.js",
        "content/content.js"
      ],
      "css": ["styles/subtitle-styles.css"],
      "run_at": "document_idle"
    }
  ],
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Live Subtitles Settings"
  },
  
  "options_page": "options/options.html",
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["styles/subtitle-styles.css"],
      "matches": ["<all_urls>"]
    }
  ]
}